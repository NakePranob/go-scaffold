{
  "name": "@nakedev/go-scaffold",
  "version": "0.1.2",
  "description": "Scaffold Gin + GORM + Postgres Go backend projects with a consistent domain-module standard",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NakePranob/go-scaffold.git"
  },
  "bin": {
    "go-scaffold": "./bin/go-scaffold.js"
  },
  "files": [
    "dist",
    "templates",
    "bin"
  ],
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node scripts/smoke-test.mjs",
    "verify": "pnpm run build && pnpm run test",
    "prepublishOnly": "pnpm run verify"
  },
  "keywords": [
    "go",
    "gin",
    "gorm",
    "scaffold",
    "cli",
    "generator"
  ],
  "author": "nakedev",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.5.1",
    "commander": "^15.0.0",
    "fs-extra": "^11.3.0",
    "handlebars": "^4.7.8",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
